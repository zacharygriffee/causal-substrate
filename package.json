{
  "name": "causal-substrate",
  "version": "0.1.0",
  "description": "Ontology-first kernel for observer-scoped causal continuity.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "example": "tsx examples/minimal-continuity.ts",
    "test": "tsx --test test/kernel.test.ts"
  },
  "keywords": [
    "causality",
    "observer",
    "substrate",
    "continuity",
    "ontology"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  }
}
